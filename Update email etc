  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  input, textarea, select { width: 100%; background: var(--smoke); border: 1px solid rgba(232,82,10,0.15); color: var(--cream); padding: 1rem 1.2rem; font-family: 'Barlow', sans-serif; font-size: 0.9rem; outline: none; transition: border-color 0.2s; }
  input:focus, textarea:focus, select:focus { border-color: var(--orange); }
