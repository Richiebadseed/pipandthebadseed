  footer { padding: 3rem; display: flex; justify-content: space-between; align-items: center; border-top: 1px solid rgba(232,82,10,0.1); }
  .footer-logo { font-family: 'Bebas Neue', sans-serif; font-size: 1.8rem; letter-spacing: 0.1em; color: var(--orange); }
  .footer-copy { font-size: 0.75rem; color: var(--grey); letter-spacing: 0.1em; }
  .social-links { display: flex; gap: 1.5rem; }
  .social-links a { font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--grey); text-decoration: none; transition: color 0.2s; }
  .social-links a:hover { color: var(--orange); }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
  .reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease, transform 0.7s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  @media (max-width: 768px) {
    nav { padding: 1.2rem 1.5rem; } nav ul { display: none; }
    .hero { padding: 0 1.5rem 4rem; } section { padding: 5rem 1.5rem; }
    .about { grid-template-columns: 1fr; gap: 3rem; } .about-right { order: -1; }
    .repertoire-grid { grid-template-columns: 1fr; }
    .event-item { grid-template-columns: 80px 1fr; }
    .form-row { grid-template-columns: 1fr; }
    footer { flex-direction: column; gap: 1.5rem; text-align: center; }
  }
</style>
</head>
